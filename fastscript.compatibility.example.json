    "app/styles.css",
    "app/design/tokens.json"
  ],
  "protectedDirectories": [
    "app/design",
    "app/assets"
  ],
  "protectedGlobs": [
    "app/pages/**/__snapshots__/**"
  ],
  "protectedExtensions": [
    ".lock"
  ],
