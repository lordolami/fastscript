{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FastScript",
  "scopeName": "source.fastscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#templateString" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#reactive" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.fastscript", "match": "//.*$" },
        { "name": "comment.block.fastscript", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fastscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.fastscript", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.fastscript",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.fastscript", "match": "\\\\." }]
        }
      ]
    },
    "templateString": {
      "name": "string.template.fastscript",
      "begin": "`",
      "end": "`",
      "patterns": [
        { "name": "constant.character.escape.fastscript", "match": "\\\\." },
        { "include": "#templateInterpolation" },
        { "include": "#templateHtmlTag" },
        { "include": "#templateHtmlAttribute" },
        { "include": "#templateHtmlEvent" }
      ]
    },
    "templateInterpolation": {
      "name": "meta.interpolation.fastscript",
      "begin": "\\$\\{",
      "end": "\\}",
      "patterns": [
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#reactive" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#strings" }
      ]
    },
    "templateHtmlTag": {
      "name": "entity.name.tag.fastscript",
      "match": "</?[A-Za-z][A-Za-z0-9:-]*"
    },
    "templateHtmlAttribute": {
      "name": "entity.other.attribute-name.fastscript",
      "match": "\\b[A-Za-z_:][A-Za-z0-9_:.-]*(?=\\s*=)"
    },
    "templateHtmlEvent": {
      "name": "support.type.event.fastscript",
      "match": "\\bon:[A-Za-z][A-Za-z0-9:-]*(?=\\s*=)"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fastscript",
          "match": "\\b(export|default|function|fn|return|if|else|for|while|do|switch|case|break|continue|try|catch|finally|throw|new|async|await|import|from|as|state|const|let|var|class|extends)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.fastscript", "match": "\\b(str|string|int|float|number|bool|boolean|void|unknown|any|array)\\b" }
      ]
    },
    "reactive": {
      "patterns": [
        { "name": "keyword.other.reactive.fastscript", "match": "~[A-Za-z_$][\\w$]*" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.fastscript", "match": "\\b\\d+(?:\\.\\d+)?\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.fastscript", "match": "(\\+\\+|--|===|!==|==|!=|<=|>=|&&|\\|\\||\\?\\?|=>|[+\\-*/%=!<>?:|&])" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "entity.name.function.fastscript", "match": "\\b([A-Za-z_$][\\w$]*)\\s*(?=\\()" }
      ]
    }
  }
}

