{
  "name": "fastscript-language",
  "displayName": "FastScript FS Toolkit",
  "description": "Syntax and language support for FastScript (.fs)",
  "version": "0.1.4",
  "publisher": "lakesbim-velox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lordolami/fastscript.git"
  },
  "icon": "media/fastscript-icon.png",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:fastscript"],
  "main": "./extension.js",
  "contributes": {
    "languages": [{
      "id": "fastscript",
      "aliases": ["FastScript", "fastscript"],
      "extensions": [".fs"],
      "icon": {
        "light": "./media/fs-file.svg",
        "dark": "./media/fs-file.svg"
      },
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "fastscript",
      "scopeName": "source.fastscript",
      "path": "./syntaxes/fastscript.tmLanguage.json"
    }],
    "snippets": [{
      "language": "fastscript",
      "path": "./snippets/fastscript.code-snippets"
    }],
    "iconThemes": [{
      "id": "fastscript-icons",
      "label": "FastScript Icons",
      "path": "./icons/fastscript-icon-theme.json"
    }]
  },
  "scripts": {
    "test:lsp": "node ./lsp/smoke-test.cjs",
    "package:vsix": "npx @vscode/vsce package",
    "publish:check": "npx @vscode/vsce ls",
    "publish:marketplace": "npx @vscode/vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.27.0",
    "typescript": "^5.9.3"
  }
}
