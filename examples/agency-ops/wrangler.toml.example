name = "agency-ops"
main = "dist/worker.js"
compatibility_date = "2026-04-16"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = "dist"
binding = "ASSETS"

[vars]
NODE_ENV = "production"
FASTSCRIPT_DEPLOY_TARGET = "cloudflare"
AGENCY_OPS_APP_NAME = "Agency Ops SaaS"
AGENCY_OPS_SUPPORT_EMAIL = "ops@example.com"
AGENCY_OPS_NOTIFY_FROM = "notifications@example.com"
AGENCY_OPS_PRIMARY_REGION = "global"

[observability.logs]
enabled = true

